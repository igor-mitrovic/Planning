digraph DrivingFocusTree {
    graph [
        rankdir=LR,
        splines=ortho,
        nodesep=0.45,
        ranksep=0.8,
        bgcolor="#0f1115"
    ];

    node [
        shape=polygon,
        sides=6,
        style="filled",
        fontname="Arial",
        fontsize=11,
        color="#9aa4b2",
        fillcolor="#1b1f27",
        fontcolor="#f5f7fa",
        margin="0.18,0.12"
    ];

    edge [
        color="#7f8ea3",
        penwidth=1.4,
        arrowsize=0.8
    ];

    // =========================
    // PREREQUISITES
    // =========================
    licence [label="Get Driving Licence"];
    car [label="Buy a Car"];
    start [label="Begin Driving Development", shape=ellipse, fillcolor="#243447"];

    licence -> start;
    car -> start;

    // =========================
    // REACTIVATION
    // =========================
    roadsigns [label="Relearn Road Signs"];
    theory [label="Relearn Intersections\nand Theory"];
    handling [label="Relearn Car Handling"];
    clutch [label="Practice Clutch Control"];
    familiar [label="Learn Car Dimensions\n& Controls"];
    checks [label="Pre-Drive Routine"];
    redo20 [label="Redo 20 Hours of Driving", fillcolor="#2a2f3a"];

    start -> roadsigns;
    start -> theory;
    start -> handling;

    handling -> clutch;
    clutch -> familiar;

    roadsigns -> checks;
    theory -> checks;

    familiar -> redo20;
    checks -> redo20;
    clutch -> redo20;

    // =========================
    // FOUNDATIONS
    // =========================
    short_routes [label="Drive Familiar Routes"];
    city_basic [label="Basic City Driving"];
    parking_basic [label="Basic Parking"];
    weather_basic [label="Light Rain / Night Driving"];

    redo20 -> short_routes;
    redo20 -> city_basic;
    redo20 -> parking_basic;

    short_routes -> city_basic;
    short_routes -> parking_basic;

    city_basic -> weather_basic;
    parking_basic -> weather_basic;

    // =========================
    // INDEPENDENCE
    // =========================
    solo [label="Drive Solo"];
    navigation [label="Use Navigation"];
    traffic [label="Handle Dense Traffic"];
    hill [label="Hill Starts"];
    routine [label="Driving Routine"];

    weather_basic -> solo;
    weather_basic -> navigation;
    city_basic -> traffic;
    parking_basic -> hill;

    solo -> routine;
    navigation -> routine;
    traffic -> routine;
    hill -> routine;

    // =========================
    // MILEAGE
    // =========================
    km100 [label="100 km"];
    km500 [label="500 km"];
    km1000 [label="1000 km"];
    km2500 [label="2500 km"];
    km5000 [label="5000 km", shape=doubleoctagon, fillcolor="#2d3e2f"];

    routine -> km100;
    km100 -> km500;
    km500 -> km1000;
    km1000 -> km2500;
    km2500 -> km5000;

    // =========================
    // LONG DISTANCE REQUIREMENTS
    // =========================
    lt_distance [label="150–300 km"];
    lt_duration [label="2–5 Hours"];
    lt_area [label="Outside Familiar Area"];
    lt_env [label="City + Highway"];
    lt_nav [label="Independent Navigation"];
    lt_nohelp [label="No Coaching"];
    lt_logistics [label="Fuel Planning"];
    lt_control [label="No Panic / Full Control"];

    long_trip [label="Long-Distance Trip", shape=doubleoctagon, fillcolor="#2d3e2f"];

    lt_distance -> long_trip;
    lt_duration -> long_trip;
    lt_area -> long_trip;
    lt_env -> long_trip;
    lt_nav -> long_trip;
    lt_nohelp -> long_trip;
    lt_logistics -> long_trip;
    lt_control -> long_trip;

    // dependencies feeding requirements
    km1000 -> lt_distance;
    routine -> lt_duration;
    navigation -> lt_area;
    highway [label="Drive Highway"];
    highway -> lt_env;
    navigation -> lt_nav;
    solo -> lt_nohelp;
    routine -> lt_logistics;
    traffic -> lt_control;

    // =========================
    // MASTERY
    // =========================
    bad_weather [label="Heavy Rain Driving"];
    maintenance [label="Car Maintenance"];
    incidents [label="Handle Incidents"];

    confident [label="Confident Driver", shape=doubleoctagon, fillcolor="#243b55"];

    routine -> highway;
    routine -> maintenance;

    km500 -> bad_weather;
    maintenance -> incidents;

    long_trip -> confident;
    km5000 -> confident;
    bad_weather -> confident;
    incidents -> confident;
}