digraph Sexual_Competence_Tree {
    rankdir=LR;
    splines=ortho;
    nodesep=0.7;
    ranksep=1.0;

    node [
        shape=box,
        style="rounded,filled",
        fillcolor="#d9d9d9",
        color="#444444",
        fontname="Arial",
        fontsize=11,
        margin="0.18,0.10"
    ];

    edge [
        color="#555555",
        penwidth=1.4,
        arrowsize=0.8
    ];

    Start [label="Start"];
    Hygiene [label="Personal Hygiene\n& Grooming"];
    Fitness [label="Basic Fitness\n& Energy"];
    Consent [label="Consent\nUnderstanding"];
    Communication [label="Communication\nBasics"];
    Opportunity [label="Create\nOpportunity"];
    FirstExperience [label="First Sexual\nExperience"];
    Comfort [label="Comfort\n& Calmness"];
    Confidence [label="Sexual\nConfidence"];
    Awareness [label="Partner\nAwareness"];
    Exp5 [label="5 Positive\nExperiences"];
    Exp15 [label="15 Positive\nExperiences"];
    Consistency [label="Consistent\nPerformance"];
    Competence [label="Sexual\nCompetence", shape=doubleoctagon, fillcolor="#f3d37a"];

    Start -> Hygiene;
    Hygiene -> Fitness;
    Fitness -> Consent;
    Consent -> Communication;
    Communication -> Opportunity;
    Opportunity -> FirstExperience;
    FirstExperience -> Comfort;
    Comfort -> Confidence;
    Confidence -> Awareness;
    Awareness -> Exp5;
    Exp5 -> Exp15;
    Exp15 -> Consistency;
    Consistency -> Competence;
}