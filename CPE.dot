digraph CPE_Official_Branch_Focus_Tree {
    graph [
        rankdir=TB,
        splines=ortho,
        nodesep=0.55,
        ranksep=0.85,
        bgcolor="#0f1117",
        pad=0.4
    ];

    node [
        shape=box,
        style="rounded,filled",
        fontname="Arial",
        fontsize=11,
        margin="0.14,0.09",
        color="#c9aa71",
        penwidth=2,
        fillcolor="#1f2430",
        fontcolor="#f4e8c1"
    ];

    edge [
        color="#c9aa71",
        penwidth=2,
        arrowsize=0.8
    ];

    // =========================
    // ROOT / META
    // =========================

    CPE [
        label="CPE CAMPAIGN\nCambridge C2 Proficiency\nExam: 20 June 2026\nTotal: 112h",
        fillcolor="#3a2f1b",
        fontsize=14,
        penwidth=3
    ];

    Diagnostic [
        label="Diagnostic Mock Exam\n4h\nFind Weak Branches",
        fillcolor="#243247"
    ];

    ErrorLog [
        label="Error Log System\n6h\nTrack + Repair Mistakes",
        fillcolor="#243247"
    ];

    CPE -> Diagnostic;
    Diagnostic -> ErrorLog;

    // =========================
    // OFFICIAL SCORE BRANCHES
    // =========================

    ReadingCore [
        label="READING BRANCH\n18h",
        fillcolor="#263a2a",
        penwidth=3
    ];

    UseCore [
        label="USE OF ENGLISH BRANCH\n28h + 23h Playlist",
        fillcolor="#3a2636",
        penwidth=3
    ];

    WritingCore [
        label="WRITING BRANCH\n24h",
        fillcolor="#3a3326",
        penwidth=3
    ];

    ListeningCore [
        label="LISTENING BRANCH\n16h",
        fillcolor="#26343a",
        penwidth=3
    ];

    SpeakingCore [
        label="SPEAKING BRANCH\n14h",
        fillcolor="#32263a",
        penwidth=3
    ];

    ErrorLog -> ReadingCore;
    ErrorLog -> UseCore;
    ErrorLog -> WritingCore;
    ErrorLog -> ListeningCore;
    ErrorLog -> SpeakingCore;

    // =========================
    // READING BRANCH
    // =========================

    SBReading [
        label="Objective Proficiency\nReading Units\n10h",
        fillcolor="#1f3324"
    ];

    WBReading [
        label="Workbook Reading Practice\n5h",
        fillcolor="#1f3324"
    ];

    R6 [
        label="Gapped Text Drill\n3h\nCohesion + Structure",
        fillcolor="#41582d",
        penwidth=3
    ];

    ReadingCore -> SBReading;
    SBReading -> WBReading;
    WBReading -> R6;

    // =========================
    // USE OF ENGLISH BRANCH
    // =========================

    SBUoE [
        label="Objective Proficiency\nUse of English Units\n6h",
        fillcolor="#331f2e"
    ];

    WBUoE [
        label="Workbook Use of English\n8h",
        fillcolor="#331f2e"
    ];

    PlaylistPass1 [
        label="Use of English Playlist\nPass I\n11.5h",
        fillcolor="#331f2e"
    ];

    PlaylistPass2 [
        label="Use of English Playlist\nPass II\n11.5h",
        fillcolor="#331f2e"
    ];

    Transformations [
        label="Key Word Transformations\n8h\nBOSS NODE",
        fillcolor="#5a2d4d",
        penwidth=4
    ];

    UseCore -> SBUoE;
    SBUoE -> WBUoE;
    WBUoE -> PlaylistPass1;
    PlaylistPass1 -> PlaylistPass2;
    PlaylistPass2 -> Transformations;

    // =========================
    // WRITING BRANCH
    // =========================

    SBWriting [
        label="Objective Proficiency\nWriting Units\n10h",
        fillcolor="#332c1f"
    ];

    WBWriting [
        label="Workbook Writing Practice\n5h",
        fillcolor="#332c1f"
    ];

    EssayDrills [
        label="Compulsory Essay Drills\n6h\nPart 1 Priority",
        fillcolor="#5a4a2d",
        penwidth=3
    ];

    OptionalWriting [
        label="Optional Task Drills\n3h\nArticle / Report / Review",
        fillcolor="#332c1f"
    ];

    WritingCore -> SBWriting;
    SBWriting -> WBWriting;
    WBWriting -> EssayDrills;
    EssayDrills -> OptionalWriting;

    // =========================
    // LISTENING BRANCH
    // =========================

    SBListening [
        label="Objective Proficiency\nListening Units\n8h",
        fillcolor="#1f2e33"
    ];

    WBListening [
        label="Workbook Listening Practice\n4h",
        fillcolor="#1f2e33"
    ];

    L4 [
        label="Multiple Matching Drill\n4h\nSpeaker Attitude",
        fillcolor="#2d4e5a",
        penwidth=3
    ];

    ListeningCore -> SBListening;
    SBListening -> WBListening;
    WBListening -> L4;

    // =========================
    // SPEAKING BRANCH
    // =========================

    SBSpeaking [
        label="Objective Proficiency\nSpeaking Tasks\n6h",
        fillcolor="#2d1f33"
    ];

    WBSpeaking [
        label="Workbook Speaking Support\n3h",
        fillcolor="#2d1f33"
    ];

    LongTurn [
        label="Long Turn + Discussion\n5h\nSymbolic Capital Node",
        fillcolor="#4b2d5a",
        penwidth=3
    ];

    SpeakingCore -> SBSpeaking;
    SBSpeaking -> WBSpeaking;
    WBSpeaking -> LongTurn;

    // =========================
    // FINAL INTEGRATION
    // =========================

    Mock1 [
        label="Full Mock Exam I\n3h\nTimed Simulation",
        fillcolor="#243247"
    ];

    Repair [
        label="Weakness Repair Cycle\n3h\nFix Top 10 Errors",
        fillcolor="#243247"
    ];

    Mock2 [
        label="Full Mock Exam II\n3h\nFinal Readiness Check",
        fillcolor="#243247"
    ];

    FinalReview [
        label="FINAL REVIEW\nExam Strategy\nLight Revision",
        fillcolor="#3a2f1b",
        penwidth=3
    ];

    R6 -> Mock1;
    Transformations -> Mock1;
    OptionalWriting -> Mock1;
    L4 -> Mock1;
    LongTurn -> Mock1;

    Mock1 -> Repair;
    Repair -> Mock2;
    Mock2 -> FinalReview;

    // =========================
    // RANKING FOR VISUAL BALANCE
    // =========================

    { rank=same; ReadingCore; UseCore; WritingCore; ListeningCore; SpeakingCore; }
    { rank=same; SBReading; SBUoE; SBWriting; SBListening; SBSpeaking; }
    { rank=same; WBReading; WBUoE; WBWriting; WBListening; WBSpeaking; }
    { rank=same; R6; PlaylistPass1; EssayDrills; L4; LongTurn; }
    { rank=same; PlaylistPass2; OptionalWriting; }
}